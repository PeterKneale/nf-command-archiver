plugins {
    id 'nf-command-archiver@0.1.0'
}

commandArchiver {
    enabled       = true
    output        = "${launchDir}/command-archive.tar.gz"
    files         = ['.command.sh', '.command.log']
    includeCached = true
    processFilter = '.*ALIGN.*'   // optional regex on process name; omit to capture every process
}
